{
  "name": "SpeechBoleh",
  "version": "0.6.0",
  "description": "Local Speech-to-Text and Text-to-Speech Desktop Application",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder"
  },
  "keywords": [
    "electron",
    "stt",
    "tts",
    "whisper"
  ],
  "author": "TIN WIN AUNG",
  "license": "ISC",
  "dependencies": {
    "fluent-ffmpeg": "^2.1.3"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^26.15.3"
  },
  "build": {
    "appId": "com.tinwinaung.speechapp",
    "productName": "SpeechBoleh",
    "asar": true,
    "asarUnpack": [
      "bin/**/*"
    ],
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer.js",
      "index.html",
      "index.css",
      "assets/**/*",
      "node_modules/**/*"
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "assets/soundwave_512.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}