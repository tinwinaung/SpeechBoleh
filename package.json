{
  "name": "SpeechBoleh",
  "version": "0.7.0",
  "description": "Local Speech-to-Text and Text-to-Speech Desktop Application",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder"
  },
  "keywords": [
    "electron",
    "stt",
    "tts",
    "whisper"
  ],
  "author": "TIN WIN AUNG",
  "license": "AGPL-3.0-only",
  "dependencies": {
    "fluent-ffmpeg": "^2.1.3"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^26.15.3"
  },
  "build": {
    "appId": "com.tinwinaung.speechapp",
    "productName": "SpeechBoleh",
    "asar": true,
    "asarUnpack": [
      "bin/**/*"
    ],
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer.js",
      "index.html",
      "index.css",
      "conf.json",
      "assets/**/*",
      "node_modules/**/*"
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "assets/soundwave_512.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "pkg": {
    "comment": "This pkg section is kept for backward compatibility (0.6.0 and lower), but it is not used in the current version. Please update conf.json for the correct configuration.",
    "ffmpeg": {
      "url": "https://github.com/BtbN/FFmpeg-Builds/releases/download/latest/ffmpeg-master-latest-win64-gpl.zip",
      "version": "latest"
    },
    "piper": {
      "url": "https://github.com/rhasspy/piper/releases/download/2023.11.14-2/piper_windows_amd64.zip",
      "version": "2023.11.14-2"
    },
    "whisper": {
      "url": "https://github.com/ggml-org/whisper.cpp/releases/download/v1.9.1/whisper-bin-x64.zip",
      "version": "1.9.1"
    }
  }
}